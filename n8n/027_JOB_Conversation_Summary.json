    "Parse AI Response": { "main": [[{ "node": "Update Summary", "type": "main", "index": 0 }]] },
    "Update Summary": { "main": [[{ "node": "Update AI Usage", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "availableInMCP": true }
}
