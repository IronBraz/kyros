# Kyros — Local configuration
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored; never commit it.

# === PWA (Vite) ===
# Base URL where the QR-code landing pages resolve (production domain).
# Used by the admin Control Room to preview entry-point URLs.
# Must include scheme. Example: https://kyros.example.com
VITE_QR_BASE_URL=https://your-domain.example.com

# Optional: Gemini API key (legacy, only used if AI concierge module is enabled)
GEMINI_API_KEY=

# === PostgreSQL admin user ===
# Used by database/manage_kyros_db.ps1 to create/manage the kyros_db database.
# Should be a Postgres role with CREATEDB and SUPERUSER (or sufficient) privileges.
# Defaults to 'postgres' if unset.
KYROS_PG_ADMIN_USER=postgres

# === n8n: NO env var needed ===
# The QR base URL for entry points is stored in the database, in stores.settings (JSONB).
# Set it once per store with _local/setup-store.sql.example after bootstrapping a tenant.
